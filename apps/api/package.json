{
  "name": "@iso-ocr/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "node --env-file=../../.env ../../node_modules/prisma/build/index.js generate",
    "db:migrate": "npm run db:push",
    "db:push": "node --env-file=../../.env ../../node_modules/prisma/build/index.js db push",
    "db:deploy": "npm run db:push",
    "db:studio": "node --env-file=../../.env ../../node_modules/prisma/build/index.js studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/client-textract": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.717.0",
    "@iso-ocr/shared": "file:../../packages/shared",
    "@prisma/client": "^6.1.0",
    "bullmq": "^5.34.2",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.2",
    "jszip": "^3.10.1",
    "multer": "^2.0.2",
    "nanoid": "^5.0.9",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.15.1",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/hpp": "^0.2.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.9",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
